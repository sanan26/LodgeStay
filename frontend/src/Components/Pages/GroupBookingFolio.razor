@page "/group-booking-folio/{MasterReference}"
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="folio-container">
    <div class="folio-card">
        <div class="success-icon">🎉</div>
        <h2>Group Booking Confirmed!</h2>
        <p class="master-ref">Master Reference: <strong>@MasterReference</strong></p>

        <div class="folio-details">
            <div class="detail-row">
                <span>Group Name:</span>
                <strong>@GroupName</strong>
            </div>
            <div class="detail-row">
                <span>Number of Rooms:</span>
                <strong>@RoomCount rooms</strong>
            </div>
            <div class="detail-row">
                <span>Discount Applied:</span>
                <strong>@DiscountPercent% off</strong>
            </div>
            <div class="detail-row total">
                <span>Total Amount:</span>
                <strong>Rs. @TotalAmount</strong>
            </div>
        </div>

        <div class="share-section">
            <p>📱 Share confirmation with group organizer:</p>
            <button class="btn-share" @onclick="ShareConfirmation">Share via WhatsApp</button>
        </div>

        <div class="actions">
            <button class="btn-home" @onclick="GoHome">🏠 Go to Dashboard</button>
            <button class="btn-reservations" @onclick="GoToReservations">📋 All Reservations</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string MasterReference { get; set; } = "";
    [SupplyParameterFromQuery] public string? groupName { get; set; }
    [SupplyParameterFromQuery] public int rooms { get; set; }
    [SupplyParameterFromQuery] public int discount { get; set; }
    [SupplyParameterFromQuery] public int total { get; set; }

    private string GroupName => groupName ?? "";
    private int RoomCount => rooms;
    private int DiscountPercent => discount;
    private int TotalAmount => total;

    private void GoHome()
    {
        Navigation.NavigateTo("/staff-dashboard");
    }

    private void GoToReservations()
    {
        Navigation.NavigateTo("/reservations");
    }

    private async Task ShareConfirmation()
    {
        var message = $"LodgeStay Group Booking Confirmed!\n\nReference: {MasterReference}\nGroup: {GroupName}\nRooms: {RoomCount}\nDiscount: {DiscountPercent}%\nTotal: Rs. {TotalAmount}";
        await JSRuntime.InvokeVoidAsync("alert", "Share this message: \n\n" + message);
    }
}