@page "/group-booking"
@using LodgeStay.Models
@using LodgeStay.Services
@inject NavigationManager Navigation
@inject RoomService RoomService
@inject ReservationService ReservationService

<div class="group-booking-container">
    <div class="page-header">
        <button class="btn-back" @onclick="GoBack">← Back</button>
        <h2>👨‍👩‍👧‍👦 Group / Family Booking</h2>
    </div>

    <div class="booking-form">
        <div class="form-section">
            <h3>Group Information</h3>
            <div class="form-group">
                <label>Group Name / Organizer</label>
                <input type="text" @bind="groupName" placeholder="e.g., Khan Family Reunion" />
            </div>
            <div class="form-group">
                <label>Organizer Email</label>
                <input type="email" @bind="organizerEmail" placeholder="organizer@example.com" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Check-in Date</label>
                    <input type="date" @bind="checkIn" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="form-group">
                    <label>Check-out Date</label>
                    <input type="date" @bind="checkOut" @bind:format="yyyy-MM-dd" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>Select Rooms (@selectedRooms.Count selected)</h3>
            <div class="rooms-grid">
                @foreach (var room in availableRooms)
                {
                    <div class="room-selector @(selectedRooms.Contains(room) ? "selected" : "")"
                         @onclick="() => ToggleRoom(room)">
                        <div class="room-info">
                            <strong>Room @room.RoomNo</strong>
                            <span>@room.Room_Type</span>
                            <span>Rs. @room.Price / night</span>
                        </div>
                        <div class="check-indicator">
                            @(selectedRooms.Contains(room) ? "✓" : "□")
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="summary-section">
            <h3>Booking Summary</h3>
            <div class="summary-card">
                <div class="summary-row">
                    <span>Total Nights:</span>
                    <strong>@totalNights</strong>
                </div>
                <div class="summary-row">
                    <span>Number of Rooms:</span>
                    <strong>@selectedRooms.Count</strong>
                </div>
                <div class="summary-row">
                    <span>Subtotal:</span>
                    <strong>Rs. @subtotal</strong>
                </div>
                <div class="summary-row discount">
                    <span>Group Discount (@discountPercent%):</span>
                    <strong>- Rs. @discountAmount</strong>
                </div>
                <div class="summary-row total">
                    <span>Total Payable:</span>
                    <strong>Rs. @totalPayable</strong>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">⚠️ @errorMessage</div>
        }

        <div class="form-actions">
            <button class="btn-cancel" @onclick="GoBack">Cancel</button>
            <button class="btn-confirm" @onclick="CreateGroupBooking" disabled="@(selectedRooms.Count < 2)">
                Confirm Group Booking
            </button>
        </div>
    </div>
</div>

@code {
    private string groupName = "";
    private string organizerEmail = "";
    private DateTime checkIn = DateTime.Now;
    private DateTime checkOut = DateTime.Now.AddDays(1);
    private List<Room> availableRooms = new();
    private List<Room> selectedRooms = new();
    private string errorMessage = "";

    private int totalNights => (checkOut - checkIn).Days;
    private double subtotal => selectedRooms.Sum(r => r.Price * totalNights);
    private int discountPercent => selectedRooms.Count >= 5 ? 20 : selectedRooms.Count >= 3 ? 15 : selectedRooms.Count >= 2 ? 10 : 0;
    private double discountAmount => subtotal * discountPercent / 100;
    private double totalPayable => subtotal - discountAmount;

    protected override async Task OnInitializedAsync()
    {
        await LoadRooms();
    }

    private async Task LoadRooms()
    {
        var allRooms = await RoomService.GetRoomsAsync();
        availableRooms = allRooms.Where(r => r.Status == "Available").ToList();
    }

    private void ToggleRoom(Room room)
    {
        if (selectedRooms.Contains(room))
            selectedRooms.Remove(room);
        else
            selectedRooms.Add(room);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/staff-dashboard");
    }

    private async Task CreateGroupBooking()
    {
        if (selectedRooms.Count < 2)
        {
            errorMessage = "Please select at least 2 rooms for a group booking.";
            return;
        }

        var masterRef = "GRP-" + DateTime.Now.ToString("yyyyMMddHHmmss");

        foreach (var room in selectedRooms)
        {
            var reservation = new Reservation
                {
                    BookingReference = $"{masterRef}-{room.RoomNo}",
                    GuestName = groupName,
                    GuestEmail = organizerEmail,
                    Room_ID = room.Room_ID,
                    CheckIn = checkIn,
                    CheckOut = checkOut,
                    NumberOfGuests = room.Capacity,
                    TotalPrice = (room.Price * totalNights) * (100 - discountPercent) / 100,
                    Status = "Confirmed"
                };
            await ReservationService.AddReservationAsync(reservation);
        }

        Navigation.NavigateTo($"/group-booking-folio/{masterRef}?groupName={Uri.EscapeDataString(groupName)}&rooms={selectedRooms.Count}&discount={discountPercent}&total={totalPayable}");
    }
}

<style>
    .group-booking-container {
        padding: 2rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1rem;
        max-height: 400px;
        overflow-y: auto;
    }

    .room-selector {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .room-selector:hover {
            border-color: #2e7d32;
        }

        .room-selector.selected {
            background: #e8f5e9;
            border-color: #2e7d32;
        }

    .summary-card {
        background: #f5f5f5;
        padding: 1rem;
        border-radius: 8px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
    }

        .summary-row.discount {
            color: #c62828;
        }

        .summary-row.total {
            font-size: 1.2rem;
            font-weight: bold;
            border-top: 1px solid #ddd;
            margin-top: 8px;
            padding-top: 12px;
        }

    .check-indicator {
        font-size: 1.5rem;
    }
</style>