@page "/"
@inject NavigationManager Navigation

<div class="home">
    <div class="hero">
        <h1>🏨 LodgeStay</h1>
        <h2>Smart Lodge Management</h2>
        <p>Manage reservations, track rooms, and delight your guests</p>
        <div class="buttons">
            <button class="btn" @onclick="GoToLogin">Login</button>
            <button class="btn btn-outline" @onclick="GoToRegister">Register</button>
        </div>
    </div>

    <div class="features">
        <div class="feature">
            <span class="emoji">🔍</span>
            <h3>Smart Room Finder</h3>
            <p>Find available rooms instantly</p>
        </div>
        <div class="feature">
            <span class="emoji">📋</span>
            <h3>Easy Bookings</h3>
            <p>Create and manage reservations</p>
        </div>
        <div class="feature">
            <span class="emoji">📊</span>
            <h3>Live Dashboard</h3>
            <p>Track occupancy in real-time</p>
        </div>
        <div class="feature">
            <span class="emoji">🌿</span>
            <h3>Eco Rewards</h3>
            <p>Earn points for green choices</p>
        </div>
    </div>

    <footer>
        <p>© 2024 LodgeStay</p>
    </footer>
</div>

@code {
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }
}

<style>
    .home {
        text-align: center;
        padding: 2rem;
    }

    .hero {
        padding: 3rem 1rem;
    }

    h1 {
        font-size: 3rem;
        margin: 0;
        color: #2e7d32;
    }

    h2 {
        color: #555;
        margin: 0.5rem 0;
    }

    p {
        color: #666;
        font-size: 1.1rem;
    }

    .buttons {
        margin-top: 2rem;
    }

    .btn {
        padding: 10px 24px;
        margin: 0 8px;
        background: #2e7d32;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1rem;
    }

    .btn-outline {
        background: white;
        color: #2e7d32;
        border: 2px solid #2e7d32;
    }

    .btn:hover {
        transform: translateY(-2px);
    }

    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
        padding: 2rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .feature {
        padding: 1.5rem;
        background: #f5f5f5;
        border-radius: 12px;
    }

    .emoji {
        font-size: 2.5rem;
        display: block;
    }

    .feature h3 {
        color: #2e7d32;
        margin: 0.5rem 0;
    }

    .feature p {
        font-size: 0.9rem;
        margin: 0;
    }

    footer {
        margin-top: 3rem;
        padding: 1rem;
        color: #888;
    }
</style>