@page "/booking-confirmation/{BookingReference}"
@using LodgeStay.Models
@using LodgeStay.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ReservationService ReservationService

<div class="confirmation-container">
    <div class="confirmation-card">
        <div class="success-icon">✅</div>
        <h2>Booking Confirmed!</h2>
        <p class="booking-id">Booking ID: <strong>@BookingReference</strong></p>

        @if (isLoading)
        {
            <p>Loading booking details...</p>
        }
        else if (reservation != null)
        {
            <div class="details">
                <div class="detail-row">
                    <span class="detail-label">Guest Name</span>
                    <span class="detail-value">@reservation.GuestName</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Room</span>
                    <span class="detail-value">Room @reservation.Room_ID</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Check-in</span>
                    <span class="detail-value">@reservation.CheckIn.ToString("dd MMM yyyy")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Check-out</span>
                    <span class="detail-value">@reservation.CheckOut.ToString("dd MMM yyyy")</span>
                </div>
                <div class="detail-row total">
                    <span class="detail-label">Total Price</span>
                    <span class="detail-value">Rs. @reservation.TotalPrice</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Status</span>
                    <span class="detail-value">@reservation.Status</span>
                </div>
            </div>
        }
        else
        {
            <div class="error-message">
                <p>⚠️ Booking not found.</p>
                <p>Please check your booking reference and try again.</p>
            </div>
        }

        <div class="actions">
            <button class="btn-home" @onclick="GoHome">🏠 Go Back</button>
            <button class="btn-reservations" @onclick="GoToReservations">📋 All Reservations</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string BookingReference { get; set; } = "";

    private Reservation? reservation = null;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBookingDetails();
    }

    private async Task LoadBookingDetails()
    {
        isLoading = true;

        // Try to get from query parameters first (for new bookings)
        var guestName = GetQueryString("guest");
        var room = GetQueryString("room");
        var checkin = GetQueryString("checkin");
        var checkout = GetQueryString("checkout");
        var total = GetQueryString("total");

        if (!string.IsNullOrEmpty(guestName) && !string.IsNullOrEmpty(room))
        {
            // New booking - use query parameters
            reservation = new Reservation
                {
                    BookingReference = BookingReference,
                    GuestName = Uri.UnescapeDataString(guestName),
                    Room_ID = int.TryParse(room, out int roomId) ? roomId : 0,
                    CheckIn = DateTime.TryParse(checkin, out DateTime ci) ? ci : DateTime.Now,
                    CheckOut = DateTime.TryParse(checkout, out DateTime co) ? co : DateTime.Now.AddDays(1),
                    TotalPrice = double.TryParse(total, out double price) ? price : 0,
                    Status = "Confirmed"
                };
        }
        else
        {
            // Existing booking - get from service
            List<Reservation> reservations = await ReservationService.GetReservationByReferenceAsync(BookingReference);
        }

        isLoading = false;
    }

    private string GetQueryString(string key)
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        return query[key] ?? "";
    }

    private async Task GoHome()
    {
        // Use browser history to go back
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private void GoToReservations()
    {
        Navigation.NavigateTo("/reservations");
    }
}

<style>
    .confirmation-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
        padding: 2rem;
    }

    .confirmation-card {
        background: white;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        width: 100%;
        max-width: 500px;
        text-align: center;
    }

    .success-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    h2 {
        color: #2e7d32;
        margin-bottom: 0.5rem;
    }

    .booking-id {
        color: #888;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }

    .details {
        text-align: left;
        margin: 1.5rem 0;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .detail-label {
        color: #888;
        font-size: 0.9rem;
    }

    .detail-value {
        font-weight: 600;
        color: #333;
        font-size: 0.9rem;
    }

    .total .detail-value {
        color: #2e7d32;
        font-size: 1.1rem;
    }

    .error-message {
        background: #ffebee;
        padding: 1rem;
        border-radius: 8px;
        margin: 1rem 0;
        color: #c62828;
    }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .btn-home {
        flex: 1;
        padding: 12px;
        background: #f5f5f5;
        color: #555;
        border: 1px solid #ddd;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
    }

    .btn-reservations {
        flex: 1;
        padding: 12px;
        background: #2e7d32;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
    }

        .btn-reservations:hover {
            background: #1b5e20;
        }
</style>