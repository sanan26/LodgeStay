@page "/booking-confirmation/{BookingReference}"
@using LodgeStay.Data
@using LodgeStay.Models
@inject DatabaseContext DbContext
@inject NavigationManager Navigation

<div class="confirmation-container">
    @if (reservation != null)
    {
            <div class="confirmation-card">
                <div class="success-icon">✅</div>
                <h2>Booking Confirmed!</h2>
                <p class="booking-id">Booking ID: <strong>@reservation.BookingReference</strong></p>

                <div class="details">
                    <div class="detail-row">
                        <span class="detail-label">Guest Name</span>
                        <span class="detail-value">@reservation.GuestName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">@reservation.GuestEmail</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Phone</span>
                        <span class="detail-value">@reservation.GuestPhone</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Room</span>
                        <span class="detail-value">@reservation.Room_ID</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Check-in</span>
                        <span class="detail-value">@reservation.CheckIn.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Check-out</span>
                        <span class="detail-value">@reservation.CheckOut.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Guests</span>
                        <span class="detail-value">@reservation.NumberOfGuests</span>
                    </div>
                    <div class="detail-row total">
                        <span class="detail-label">Total Price</span>
                        <span class="detail-value">Rs. @reservation.TotalPrice</span>
                    </div>
                </div>

                <div class="actions">
                    <button class="btn-home" @onclick="GoHome">🏠 Go to Dashboard</button>
                    <button class="btn-reservations" @onclick="GoToReservations">📋 All Reservations</button>
                </div>
            </div>
    }
    else
    {
            <p>Loading booking details...</p>
    }
</div>

@code {
    [Parameter] public string BookingReference { get; set; } = "";
    private Reservation? reservation;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await DbContext.GetReservationsAsync();
            reservation = all.FirstOrDefault(r => r.BookingReference == BookingReference);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private void GoToReservations()
    {
        Navigation.NavigateTo("/reservations");
    }
}

<style>
    .confirmation-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
        padding: 2rem;
    }
    .confirmation-card {
        background: white;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        width: 100%;
        max-width: 500px;
        text-align: center;
    }
    .success-icon { font-size: 4rem; margin-bottom: 1rem; }
    h2 { color: #2e7d32; margin-bottom: 0.5rem; }
    .booking-id { color: #888; margin-bottom: 1.5rem; font-size: 0.95rem; }
    .details { text-align: left; margin: 1.5rem 0; }
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .detail-label { color: #888; font-size: 0.9rem; }
    .detail-value { font-weight: 600; color: #333; font-size: 0.9rem; }
    .total .detail-value { color: #2e7d32; font-size: 1.1rem; }
    .actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .btn-home {
        flex: 1;
        padding: 12px;
        background: #f5f5f5;
        color: #555;
        border: 1px solid #ddd;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
    }
    .btn-reservations {
        flex: 1;
        padding: 12px;
        background: #2e7d32;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
    }
    .btn-reservations:hover { background: #1b5e20; }
</style>